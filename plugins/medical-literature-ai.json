      "required": false,
      "help": "Affects customization: population.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
    },
    {
      "key": "study_types",
      "label": "study types",
      "type": "text",
      "required": false,
      "help": "Affects customization: study types.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
