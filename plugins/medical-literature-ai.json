      "help": "Affects customization: inclusion/exclusion criteria.",
      "affects": [
        "prompt",
        "validation",
        "workflow",
        "export"
      ],
      "default": ""
    },
    {
      "key": "citation_style",
      "label": "citation style",
      "type": "select",
      "required": false,
      "help": "Affects customization: citation style.",
      "affects": [
        "prompt",
        "validation",
